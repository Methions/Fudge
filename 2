    local function resizeDisplay(animated)
        local size = TextService:GetTextSize(KeyDisplay.Text, 10, Enum.Font.GothamBold, Vector2.new(1000, 1000))
        local width = math.max(40, size.X + 20)
        if animated then
            Tween(KeyDisplay, {Size = UDim2.new(0, width, 0, 22)}, 0.14)
        else
            KeyDisplay.Size = UDim2.new(0, width, 0, 22)
        end
    end

    local function setIdleVisual()
        Tween(KBFrame, {BackgroundColor3 = Color3.fromRGB(18, 18, 18)}, 0.14)
        Tween(KBStroke, {Color = Border}, 0.14)
        Tween(KBScale, {Scale = 1}, 0.14)
        Tween(KeyScale, {Scale = 1}, 0.14)
        Tween(KDStroke, {Color = Color3.fromRGB(30, 30, 30)}, 0.14)
    end

    local function setListeningVisual()
        Tween(KBFrame, {BackgroundColor3 = Color3.fromRGB(28, 28, 28)}, 0.12)
        Tween(KBStroke, {Color = Accent}, 0.12)
        Tween(KBScale, {Scale = 1.02}, 0.12)
        Tween(KeyScale, {Scale = 1.05}, 0.12)
        Tween(KDStroke, {Color = Color3.fromRGB(90, 90, 90)}, 0.12)
    end

    local function setKey(key, animate)
        currentKey = key
        KeyDisplay.Text = currentKey and keyText(currentKey) or "None"
        KeyDisplay.TextColor3 = currentKey and TxtPri or TxtMut
        resizeDisplay(animate)
        if animate then
            Tween(KeyScale, {Scale = 1.04}, 0.08)
            task.delay(0.08, function()
                if KeyScale.Parent then
                    Tween(KeyScale, {Scale = 1}, 0.1)
                end
            end)
        end
    end

    local function stopListening(keepOld)
        listening = false
        if keepOld then
            setKey(previousKey, true)
        end
        setIdleVisual()
    end

    local function startListening()
        previousKey = currentKey
        listening = true
        KeyDisplay.Text = "..."
        KeyDisplay.TextColor3 = TxtPri
        resizeDisplay(true)
        setListeningVisual()
    end

    inputConnection = UserInputService.InputBegan:Connect(function(input)
        if listening then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Escape then
                    stopListening(true)
                else
                    stopListening(false)
                    setKey(input.KeyCode, true)
                end
            else
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.MouseButton2
                    or input.UserInputType == Enum.UserInputType.MouseButton3 then
                    stopListening(false)
                    setKey(input.UserInputType, true)
                end
            end
            return
        end

        if not currentKey then
            return
        end

        local triggered = false

        if currentKey.EnumType == Enum.KeyCode then
            triggered = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == currentKey
        elseif currentKey.EnumType == Enum.UserInputType then
            triggered = input.UserInputType == currentKey
        end

        if triggered then
            Tween(KBFrame, {BackgroundColor3 = Color3.fromRGB(24, 24, 24)}, 0.06)
            Tween(KBScale, {Scale = 0.98}, 0.06)
            Tween(KeyScale, {Scale = 0.98}, 0.06)
            callback(currentKey)
            task.delay(0.08, function()
                if KBFrame.Parent and not listening then
                    setIdleVisual()
                end
            end)
        end
    end)

    KBHit.MouseEnter:Connect(function()
        if not listening then
            Tween(KBFrame, {BackgroundColor3 = Color3.fromRGB(24, 24, 24)}, 0.12)
            Tween(KBStroke, {Color = Color3.fromRGB(50, 50, 50)}, 0.12)
            Tween(KBScale, {Scale = 1.01}, 0.12)
        end
    end)

    KBHit.MouseLeave:Connect(function()
        if not listening then
            setIdleVisual()
        end
    end)

    KBHit.MouseButton1Click:Connect(function()
        if listening then
            stopListening(true)
        else
            startListening()
        end
    end)

    if currentKey then
        setKey(currentKey, false)
    else
        resizeDisplay(false)
    end

    setIdleVisual()

    function KBFunc:SetKey(key)
        setKey(normalizeKey(key), true)
    end

    function KBFunc:GetKey()
        return currentKey
    end

    function KBFunc:SetText(newText)
        KBLabel.Text = tostring(newText)
    end

    table.insert(FeatureRegistry, {
        name = tostring(KBName),
        tabName = Name,
        sectionName = SectionName,
        instance = KBFrame,
        tabBtn = TabBtn
    })

    return KBFunc
end

