	function _G.NaJaSwitchTab(targetTabName)
		if not TabContainer or not Bottom then return end
		
		local targetTabBtn = nil
		local targetPage = nil
		local targetBgImage = nil
		
		for _, child in ipairs(TabContainer:GetChildren()) do
			if child:IsA("TextButton") and child.Name == targetTabName .. "Tab" then
				targetTabBtn = child
				break
			end
		end
		
		if not targetTabBtn then return end
		
		for _, child in ipairs(Bottom:GetChildren()) do
			if child:IsA("ScrollingFrame") and child.Name == targetTabName .. "Page" then
				targetPage = child
			end
			if child:IsA("ImageLabel") and child.Name == targetTabName .. "BgImage" then
				targetBgImage = child
			end
		end
		
		if not targetPage then return end
		if targetPage.Visible then return end
		
		for _, x in pairs(TabContainer:GetChildren()) do
			if x:IsA("TextButton") then
				local pill = x:FindFirstChild("Indicator")
				local pillR = x:FindFirstChild("IndicatorRight")
				local ic = x:FindFirstChild("TabIcon")
				local lbl = x:FindFirstChild("TabLabel")
				local stk = x:FindFirstChildOfClass("UIStroke")
				local g = x:FindFirstChildOfClass("UIGradient")
				
				if pill then pill.Visible = false; pill.Size = UDim2.new(0, 0, 0, 0); pill.BackgroundTransparency = 1 end
				if pillR then pillR.Visible = false; pillR.Size = UDim2.new(0, 0, 0, 0); pillR.BackgroundTransparency = 1 end
				if ic then Tween(ic, {ImageColor3 = TxtMut}, 0.2) end
				if lbl then Tween(lbl, {TextColor3 = TxtMut}, 0.2); lbl.Font = Enum.Font.Gotham end
				if stk then Tween(stk, {Transparency = 1}, 0.2) end
				Tween(x, {BackgroundTransparency = 1}, 0.2)
				if g then g.Enabled = false end
			end
		end
		
		for _, y in pairs(Bottom:GetChildren()) do
			if y:IsA("ScrollingFrame") then
				y.Visible = false
			elseif y:IsA("ImageLabel") and y.Name:match("BgImage$") then
				if y.Visible then
					Tween(y, {ImageTransparency = 1}, 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
					task.delay(0.22, function()
						if y and y.Parent then y.Visible = false end
					end)
				end
			end
		end
		
		local targetLbl = targetTabBtn:FindFirstChild("TabLabel")
		local targetIc = targetTabBtn:FindFirstChild("TabIcon")
		local targetStk = targetTabBtn:FindFirstChildOfClass("UIStroke")
		local targetG = targetTabBtn:FindFirstChildOfClass("UIGradient")
		local targetPill = targetTabBtn:FindFirstChild("Indicator")
		local targetPillR = targetTabBtn:FindFirstChild("IndicatorRight")
		
		if targetLbl then
			targetLbl.Font = Enum.Font.GothamBold
			Tween(targetLbl, {TextColor3 = TxtPri}, 0.22)
		end
		if targetIc then Tween(targetIc, {ImageColor3 = Accent}, 0.22) end
		Tween(targetTabBtn, {BackgroundTransparency = 0}, 0.22)
		if targetStk then Tween(targetStk, {Transparency = 0}, 0.22) end
		if targetG then targetG.Enabled = true end
		
		if targetPill then
			targetPill.Visible = false
			targetPill.Size = UDim2.new(0, 0, 0, 0)
			targetPill.BackgroundTransparency = 1
		end
		if targetPillR then
			targetPillR.Visible = false
			targetPillR.Size = UDim2.new(0, 0, 0, 0)
			targetPillR.BackgroundTransparency = 1
		end
		
		targetPage.Visible = true
		
		if targetBgImage and targetBgImage.Image ~= "" then
			targetBgImage.Visible = true
			Tween(targetBgImage, {ImageTransparency = 0}, 0.35, Enum.EasingStyle.Quart)
		end
		
		activeTabBtn = targetTabBtn
		activeTabPage = targetPage
		
		local function animateItems(page)
			local allItems = {}
			for _, col in ipairs({page:FindFirstChild("Left"), page:FindFirstChild("Right")}) do
				if col then
					for _, section in ipairs(col:GetChildren()) do
						if section:IsA("Frame") then
							table.insert(allItems, section)
						end
					end
				end
			end
			for i, item in ipairs(allItems) do
				local origT = item.BackgroundTransparency
				item.BackgroundTransparency = 1
				task.delay((i-1) * 0.045, function()
					if not item or not item.Parent then return end
					Tween(item, {BackgroundTransparency = origT}, 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
				end)
			end
		end
		task.defer(function() animateItems(targetPage) end)
	end
	
