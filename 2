	do
		local origins = {}
		local captured = false

		local function scan(obj)
			local p = obj.Parent
			while p do
				if p == SettingsUI then return end
				p = p.Parent
			end

			if obj:IsA("GuiObject") then
				origins[obj] = {
					bg = obj.BackgroundTransparency,
					txt = (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.TextTransparency or nil,
					img = (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) and obj.ImageTransparency or nil,
				}
			end
			if obj:IsA("UIStroke") then
				origins[obj] = { stroke = obj.Transparency }
			end
			for _, child in ipairs(obj:GetChildren()) do
				scan(child)
			end
		end

		function applyGlobalTransparency(val)
			val = math.clamp(val, 0, 1)
			if not captured then
				captured = true
				scan(Main)
			end

			for obj, orig in pairs(origins) do
				if not obj or not obj.Parent then continue end

				if obj:IsA("UIStroke") then
					obj.Transparency = math.clamp(orig.stroke + (1 - orig.stroke) * val, 0, 1)
				elseif obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
					if orig.txt ~= nil then obj.TextTransparency = math.clamp(orig.txt + (1 - orig.txt) * val, 0, 1) end
					if orig.bg ~= nil then obj.BackgroundTransparency = math.clamp(orig.bg + (1 - orig.bg) * val, 0, 1) end
				elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
					if orig.img ~= nil then obj.ImageTransparency = math.clamp(orig.img + (1 - orig.img) * val, 0, 1) end
					if orig.bg ~= nil then obj.BackgroundTransparency = math.clamp(orig.bg + (1 - orig.bg) * val, 0, 1) end
				else
					if orig.bg ~= nil then obj.BackgroundTransparency = math.clamp(orig.bg + (1 - orig.bg) * val, 0, 1) end
				end
			end
		end
	end

	task.delay(1.5, function()
