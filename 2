						end
					end
					
					-- Also try to find the specific page by tab name
					if not targetPage and feature.tabBtn then
						local tabName = feature.tabBtn.Name:gsub("Tab$", "")
						targetPage = Bottom:FindFirstChild(tabName .. "Page")
					end

					-- Scroll the Page to show the feature
					if targetPage then
						task.wait(0.1)
						
						if feature.instance and feature.instance.Parent then
							-- Calculate the feature's Y position relative to the Page's content
							local featureAbsY = feature.instance.AbsolutePosition.Y
							local pageAbsY = targetPage.AbsolutePosition.Y
							local pageCanvasY = targetPage.CanvasPosition.Y
							
							-- The feature's position within the canvas
							local featureCanvasY = featureAbsY - pageAbsY + pageCanvasY
							
							-- Target scroll position: center the feature in view
							local viewHeight = targetPage.AbsoluteWindowSize.Y
							local featureHeight = feature.instance.AbsoluteSize.Y
							local targetY = math.max(0, featureCanvasY - (viewHeight / 2) + (featureHeight / 2) - 80)
							
							-- Clamp to canvas bounds
							local maxY = math.max(0, targetPage.AbsoluteCanvasSize.Y - viewHeight)
							targetY = math.clamp(targetY, 0, maxY)
							
							-- Smooth scroll
							TweenService:Create(
								targetPage,
								TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
								{ CanvasPosition = Vector2.new(0, targetY) }
							):Play()
						end
					end

					-- Flash highlight the feature 3 times
					task.wait(0.6)
					if feature.instance and feature.instance.Parent then
						flashHighlight(feature.instance)
					end
				end)
			end
		end)

		return ResultBtn
	end

	function _G.performSearch(query)
		for _, child in ipairs(_G.SPResults:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end

		query = query:lower():gsub("^%s+", ""):gsub("%s+$", "")
		if query == "" then
			_G.SPNoResults.Text = "Start typing to search..."
			_G.SPNoResults.Visible = true
			_G.SPResults.CanvasSize = UDim2.new(0, 0, 0, 40)
			return
		end

		local matches = {}
		for _, feature in ipairs(FeatureRegistry) do
			local nameMatch = feature.name and feature.name:lower():find(query, 1, true)
			local tabMatch = feature.tabName and feature.tabName:lower():find(query, 1, true)
			local secMatch = feature.sectionName and feature.sectionName:lower():find(query, 1, true)
			if nameMatch or tabMatch or secMatch then
				table.insert(matches, feature)
			end
		end

		if #matches == 0 then
			_G.SPNoResults.Text = 'No results for "' .. query .. '"'
			_G.SPNoResults.Visible = true
			_G.SPResults.CanvasSize = UDim2.new(0, 0, 0, 40)
		else
			_G.SPNoResults.Visible = false
			for _, match in ipairs(matches) do
				_G.createSearchResult(match)
			end
			_G.SPResults.CanvasSize = UDim2.new(0, 0, 0, #matches * 52 + 12)
		end
	end

	_G.SPInput:GetPropertyChangedSignal("Text"):Connect(function()
		_G.performSearch(_G.SPInput.Text)
	end)

