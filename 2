_G.UISize = "Auto"

local BASE_WIDTH = 640
local BASE_HEIGHT = 450

local MIN_SCALE = 0.45
local MAX_SCALE = 1.0
local MIN_WIDTH = 320
local MIN_HEIGHT = 240
local MAX_WIDTH = 800
local MAX_HEIGHT = 580

local SCREEN_PADDING_X = 12
local SCREEN_PADDING_Y = 12

local function getViewportScale()
	local s = workspace.CurrentCamera.ViewportSize
	local vw, vh = s.X, s.Y
	
	-- Mobile detection: if viewport is narrow, use more aggressive scaling
	local isMobile = vw < 600 or vh < 500
	local mobileScaleFactor = isMobile and 0.82 or 1.0
	
	local scaleX = (vw - SCREEN_PADDING_X * 2) / BASE_WIDTH
	local scaleY = (vh - SCREEN_PADDING_Y * 2) / BASE_HEIGHT
	
	local scale = math.min(scaleX, scaleY) * mobileScaleFactor
	
	scale = math.clamp(scale, MIN_SCALE, MAX_SCALE)
	
	return scale
end

local function getUISize()
	local scale = getViewportScale()
	
	local w = math.clamp(math.floor(BASE_WIDTH * scale + 0.5), MIN_WIDTH, MAX_WIDTH)
	local h = math.clamp(math.floor(BASE_HEIGHT * scale + 0.5), MIN_HEIGHT, MAX_HEIGHT)
	
	return UDim2.new(0, w, 0, h)
end

local targetSize = getUISize()

local function applyUISize(size)
	local s = workspace.CurrentCamera.ViewportSize
	local vw, vh = s.X, s.Y
	
	if size == "Auto" then
		targetSize = getUISize()
		
	elseif size == "Large" then
		targetSize = UDim2.new(0, 720, 0, 500)
		
	elseif size == "Big" then
		targetSize = UDim2.new(0, 640, 0, 450)
		
	elseif size == "Normal" then
		targetSize = UDim2.new(0, 520, 0, 360)
		
	elseif size == "Compact" then
		targetSize = UDim2.new(0, 480, 0, 340)
	end
	
	Main.Position = UDim2.new(0.5, 0, 0.5, 0)
	Tween(Main, {Size = targetSize}, 0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

