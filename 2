local function playSound(soundId)
    if not soundId or not Settings.soundEnabled then return end
    pcall(function()
        local snd = Instance.new("Sound")
        snd.SoundId = "rbxassetid://" .. tostring(soundId)
        snd.Volume = 0.4
        snd.Parent = SoundService
        snd:Play()
        game:GetService("Debris"):AddItem(snd, 6)
    end)
end

