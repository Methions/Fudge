		MDPad.Parent = MarkdownFrame
		MDPad.PaddingLeft = UDim.new(0, 0)
		MDPad.PaddingRight = UDim.new(0, 0)
		MDPad.PaddingTop = UDim.new(0, 0)
		MDPad.PaddingBottom = UDim.new(0, 0)

		local source = tostring(text or "")
		local inCode = false
		local codeLang = ""
		local codeLines = {}

		local function flushCode()
			if #codeLines == 0 then
				return
			end
			renderCodeBlock(MarkdownFrame, codeLang, table.concat(codeLines, "\n"))
			codeLines = {}
			codeLang = ""
		end

		for line in (source .. "\n"):gmatch("(.-)\n") do
			if inCode then
				local closeFence = line:match("^```%s*$")
				if closeFence then
					flushCode()
					inCode = false
				else
					codeLines[#codeLines + 1] = line
				end
			else
				local fenceLang = line:match("^```%s*([%w_%-]*)%s*$")
				if fenceLang ~= nil then
					inCode = true
					codeLang = fenceLang:lower()
				elseif line:match("^%s*$") then
					makeSpacer(MarkdownFrame, 8)
				elseif line:match("^%-%-%-%s*$") then
					makeRule(MarkdownFrame)
				else
					local hashes, titleText = line:match("^(#+)%s*(.+)$")
					if hashes and titleText then
						local level = #hashes
						local size = 18
						local font = Enum.Font.GothamBold
						local color = TxtPri

						if level == 1 then
							size = 30
							font = Enum.Font.GothamBlack
						elseif level == 2 then
							size = 22
						elseif level == 3 then
							size = 18
						elseif level == 4 then
							size = 16
							color = TxtPri
						else
							size = 14
							color = TxtMut
						end

						makeTextLabel(MarkdownFrame, titleText, size, font, color, false)
					elseif line:match("^>%s*(.+)$") then
						local quote = line:match("^>%s*(.+)$")
						local quoteFrame = Instance.new("Frame")
						quoteFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
						quoteFrame.BorderSizePixel = 0
						quoteFrame.Size = UDim2.new(1, 0, 0, 0)
						quoteFrame.AutomaticSize = Enum.AutomaticSize.Y
						quoteFrame.Parent = MarkdownFrame

						local quoteCorner = Instance.new("UICorner")
						quoteCorner.CornerRadius = UDim.new(0, 8)
						quoteCorner.Parent = quoteFrame

						local quoteStroke = Instance.new("UIStroke")
						quoteStroke.Color = Color3.fromRGB(32, 32, 32)
						quoteStroke.Thickness = 1
						quoteStroke.Parent = quoteFrame

						local quotePad = Instance.new("UIPadding")
						quotePad.Parent = quoteFrame
						quotePad.PaddingLeft = UDim.new(0, 12)
						quotePad.PaddingRight = UDim.new(0, 12)
						quotePad.PaddingTop = UDim.new(0, 10)
						quotePad.PaddingBottom = UDim.new(0, 10)

						makeTextLabel(quoteFrame, quote, 12, Enum.Font.Gotham, TxtMut, false)
					else
						local processedLine = parseHighlights(line)
						makeTextLabel(MarkdownFrame, processedLine, 12, Enum.Font.Gotham, TxtMut, true)
					end
				end
			end
		end

		if inCode then
			flushCode()
		end
	end

