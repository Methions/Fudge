				TextLabel.TextYAlignment = Enum.TextYAlignment.Top

				local Section = SectionContainer.Parent
				local Column = Section and Section.Parent
				local ColumnsContainer = Column and Column.Parent
				local Page = ColumnsContainer and ColumnsContainer.Parent

				local messages = {}
				if type(text) == "table" then
					for _, msg in ipairs(text) do
						table.insert(messages, tostring(msg))
					end
				else
					table.insert(messages, tostring(text))
				end

				local msgIndex = 1
				local active = false
				local lastVisible = false
				local animThread = nil

				local function runAnimation()
					if animThread then
						active = false
						task.wait(0.05)
