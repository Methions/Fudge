    KBFrame.Size = UDim2.new(1, 0, 0, 34)
    grad(KBFrame, ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(26, 26, 26)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(14, 14, 14))
    }), 90)

    local KBScale = Instance.new("UIScale")
    KBScale.Scale = 1
    KBScale.Parent = KBFrame

    local KBCorner = Instance.new("UICorner")
    KBCorner.CornerRadius = UDim.new(0, 7)
