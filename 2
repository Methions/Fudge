			local char = text:sub(i, i)
			local nextChar = text:sub(i + 1, i + 1)

			-- Check for highlight syntax: !text! or @text@ etc.
			if highlightColors[char] and nextChar ~= " " then
				local color = highlightColors[char]
				local j = i + 1
				-- Find closing marker (same char, not preceded by \)
				while j <= len do
					if text:sub(j, j) == char and text:sub(j - 1, j - 1) ~= "\\" then
						break
					end
					j = j + 1
				end

				if j <= len then
					-- Found closing marker
					local highlightedText = text:sub(i + 1, j - 1)
					-- Remove escape characters
					highlightedText = highlightedText:gsub("\\(.)", "%1")
					table.insert(result, colorWrap(highlightedText, color))
					i = j + 1
				else
					-- No closing marker, treat as normal text
					table.insert(result, escapeRichText(char))
					i = i + 1
				end
			else
				table.insert(result, escapeRichText(char))
				i = i + 1
			end
		end

		return table.concat(result)
	end

