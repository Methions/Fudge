	local function highlightLuaLine(line)
		local out = {}
		local i = 1
		local len = #line

		local function add(raw, color)
			local text = preserveSpaces(escapeRichText(raw))
			if color then
				out[#out + 1] = colorWrap(text, color)
			else
				out[#out + 1] = text
			end
		end

		while i <= len do
			local c = line:sub(i, i)
			local two = line:sub(i, i + 1)

			if two == "--" then
				add(line:sub(i), "rgb(106,153,85)")
				break
			elseif c == '"' or c == "'" then
				local quote = c
				local j = i + 1
				while j <= len do
					local ch = line:sub(j, j)
					if ch == "\\" then
						j = j + 2
					elseif ch == quote then
						j = j + 1
						break
					else
						j = j + 1
					end
				end
				add(line:sub(i, math.min(j - 1, len)), "rgb(206,145,120)")
				i = j
			elseif c:match("%d") then
				local j = i
				while j <= len and line:sub(j, j):match("[%d%.]") do
					j = j + 1
				end
				add(line:sub(i, j - 1), "rgb(181,206,168)")
				i = j
			elseif c:match("[%a_]") then
				local j = i
				while j <= len and line:sub(j, j):match("[%w_]") do
					j = j + 1
				end
				local word = line:sub(i, j - 1)
				if luaKeywords[word] then
					add(word, "rgb(86,156,214)")
				else
					add(word, nil)
				end
				i = j
			else
				add(c, nil)
				i = i + 1
			end
		end

		return table.concat(out)
	end

	local function highlightLua(code)
		local lines = {}
		local source = tostring(code or "")
		for line in (source .. "\n"):gmatch("(.-)\n") do
			lines[#lines + 1] = highlightLuaLine(line)
		end
		return table.concat(lines, "<br/>")
	end

