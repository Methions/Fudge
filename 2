do
	function scrollToInstance(scrollFrame, inst, padding)
		if not scrollFrame or not inst or not scrollFrame:IsA("ScrollingFrame") then
			return
		end

		padding = padding or 40

		-- Wait a tiny bit for layout to settle if needed
		local targetY = inst.AbsolutePosition.Y - scrollFrame.AbsolutePosition.Y + scrollFrame.CanvasPosition.Y - padding
		local maxY = math.max(0, scrollFrame.AbsoluteCanvasSize.Y - scrollFrame.AbsoluteWindowSize.Y)
		targetY = math.clamp(targetY, 0, maxY)

		-- Use a slightly longer tween for smoother scrolling
		TweenService:Create(
			scrollFrame,
			TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
			{ CanvasPosition = Vector2.new(scrollFrame.CanvasPosition.X, targetY) }
		):Play()
	end

	function flashHighlight(inst)
		if not inst or not inst.Parent then
			return
		end

		local TS = game:GetService("TweenService")

		local highlight = Instance.new("Frame")
		highlight.Name = "NaJaSearchHighlight"
		highlight.BackgroundTransparency = 1
		highlight.BorderSizePixel = 0
		highlight.Size = UDim2.new(1, 0, 1, 0)
		highlight.ZIndex = inst.ZIndex + 100
		highlight.Parent = inst

		local corner = inst:FindFirstChildOfClass("UICorner")
		if corner then
			local hc = Instance.new("UICorner")
			hc.CornerRadius = corner.CornerRadius
			hc.Parent = highlight
		end

		local glow = Instance.new("Frame")
		glow.Name = "GlowFill"
		glow.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		glow.BackgroundTransparency = 1
		glow.BorderSizePixel = 0
		glow.Size = UDim2.new(1, 0, 1, 0)
		glow.ZIndex = 1
		glow.Parent = highlight
		if corner then
			local gc = Instance.new("UICorner")
			gc.CornerRadius = corner.CornerRadius
			gc.Parent = glow
		end

		local stroke = Instance.new("UIStroke")
		stroke.Color = Color3.fromRGB(255, 255, 255)
		stroke.Thickness = 2.5
		stroke.Transparency = 1
		stroke.Parent = highlight

		local outerGlow = Instance.new("Frame")
		outerGlow.Name = "OuterGlow"
		outerGlow.BackgroundTransparency = 1
		outerGlow.BorderSizePixel = 0
		outerGlow.Position = UDim2.new(0, -6, 0, -6)
		outerGlow.Size = UDim2.new(1, 12, 1, 12)
		outerGlow.ZIndex = 0
		outerGlow.Parent = highlight

		local outerStroke = Instance.new("UIStroke")
		outerStroke.Color = Color3.fromRGB(180, 180, 255)
		outerStroke.Thickness = 4
		outerStroke.Transparency = 1
		outerStroke.Parent = outerGlow

		if corner then
			local oc = Instance.new("UICorner")
			local offset = math.min(corner.CornerRadius.Offset + 6, 24)
			if corner.CornerRadius.Scale > 0 then
				oc.CornerRadius = UDim.new(corner.CornerRadius.Scale, offset)
			else
				oc.CornerRadius = UDim.new(0, offset)
			end
			oc.Parent = outerGlow
		end

		local scaleObj = inst:FindFirstChildOfClass("UIScale")
		local origScale = 1
		local tempScale = nil
		if not scaleObj then
			tempScale = Instance.new("UIScale")
			tempScale.Parent = inst
			scaleObj = tempScale
		else
			origScale = scaleObj.Scale
		end

		local tiIn = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		local tiOut = TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

		local function flashOn()
			TS:Create(glow, tiIn, { BackgroundTransparency = 0.72 }):Play()
			TS:Create(stroke, tiIn, { Transparency = 0.05 }):Play()
			TS:Create(outerStroke, tiIn, { Transparency = 0.25 }):Play()
			TS:Create(scaleObj, tiIn, { Scale = origScale * 1.012 }):Play()
		end

		local function flashOff()
			TS:Create(glow, tiOut, { BackgroundTransparency = 1 }):Play()
			TS:Create(stroke, tiOut, { Transparency = 1 }):Play()
			TS:Create(outerStroke, tiOut, { Transparency = 1 }):Play()
			TS:Create(scaleObj, tiOut, { Scale = origScale }):Play()
		end

		for i = 1, 4 do
			flashOn()
			task.wait(0.38)
			flashOff()
			task.wait(0.28)
		end

		flashOn()
		task.wait(0.6)
		flashOff()
		task.wait(0.35)

		pcall(function() highlight:Destroy() end)
		if tempScale then
			pcall(function() tempScale:Destroy() end)
		else
			pcall(function() scaleObj.Scale = origScale end)
		end
	end

	end


