					active = true

					animThread = task.spawn(function()
						while active and Label.Parent do
							local currentMsg = messages[msgIndex]
							if not currentMsg then break end

							TextLabel.Text = ""
							for i = 1, #currentMsg do
								if not active or not Label.Parent then break end
								TextLabel.Text = currentMsg:sub(1, i)
								task.wait(speed)
							end

							if not active or not Label.Parent then break end

